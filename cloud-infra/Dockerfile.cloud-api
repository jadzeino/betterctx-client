FROM rust:1-bookworm AS builder

WORKDIR /app
COPY rust ./rust

RUN cd rust && cargo build --release --features cloud-server --bin better-ctx-cloud-api

FROM debian:bookworm-slim

RUN apt-get update \
  && apt-get install -y --no-install-recommends ca-certificates \
  && rm -rf /var/lib/apt/lists/*

COPY --from=builder /app/rust/target/release/better-ctx-cloud-api /usr/local/bin/better-ctx-cloud-api

ENV BETTERCTX_CLOUD_BIND_HOST=0.0.0.0
ENV BETTERCTX_CLOUD_BIND_PORT=8088

EXPOSE 8088

CMD ["better-ctx-cloud-api"]

